__pycache__/
*.pyc
*.pyo
*.egg-info/

# uv-managed virtual environment
.venv/

# Generated from mcp.template.json by setup.ps1 — contains machine-local
# absolute paths, so don't commit it.
mcp.json

# Per-workspace MCP registration for Claude Code — also contains a
# machine-local absolute path, so don't commit it.
.mcp.json

# Cursor MCP config — machine-local paths and board credentials.
.cursor/mcp.json

# Local environment overrides
.env

# Audit log from runtime
audit.log
.mcp-state/
