# SSH transport — board reachable over LAN / USB-Ethernet gadget.

BOARD_TRANSPORT=ssh
BOARD_NAME=linux-board-ssh
BOARD_HOST=192.168.7.2
BOARD_PORT=22
BOARD_USER=root
# Either provide a key file or a password (not both).
BOARD_KEY=/home/me/.ssh/board_rsa
# BOARD_PASSWORD=

BOARD_TIMEOUT=15
BOARD_AUDIT_LOG=./audit.log

# Optional: append additional read-only shell prefixes the model can call
# via run_shell. Comma-separated.
# BOARD_EXTRA_SHELL_PREFIXES=ethtool eth0,journalctl -n
