# ADB transport over USB. Use this when the board exposes adbd over a USB
# gadget (typical for Android boards, but also common on some embedded
# Linux SDKs that ship adbd).

BOARD_TRANSPORT=adb-usb
BOARD_NAME=linux-board-adb-usb
ADB_BINARY=adb

# Leave empty to pick the only attached device. Set when multiple devices
# are plugged in — run `adb devices -l` to find the serial.
ADB_SERIAL=

BOARD_TIMEOUT=15
BOARD_AUDIT_LOG=./audit.log
