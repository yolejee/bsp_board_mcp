# Serial UART transport — console on USB-UART (e.g. Rockchip fiq-debugger).

BOARD_TRANSPORT=serial
BOARD_NAME=linux-board-serial
BOARD_SERIAL_PORT=COM3
BOARD_SERIAL_BAUD=1500000
BOARD_SERIAL_BYTESIZE=8
BOARD_SERIAL_PARITY=N
BOARD_SERIAL_STOPBITS=1
# Login credentials if the console shows login:/Password: prompts.
# Falls back to BOARD_USER / BOARD_PASSWORD when unset.
# BOARD_SERIAL_USER=root
# BOARD_SERIAL_PASSWORD=

BOARD_TIMEOUT=15
BOARD_AUDIT_LOG=./audit.log
