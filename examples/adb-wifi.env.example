# ADB transport over WiFi / network.
#
# Prereq on the board: adbd must be in tcp mode (port 5555 by default).
# On Android: `setprop service.adb.tcp.port 5555 && stop adbd && start adbd`
# On Android 11+: pair from the device's Wireless debugging screen first,
# then `adb pair host:port` with the pairing code, then connect normally.

BOARD_TRANSPORT=adb-wifi
BOARD_NAME=linux-board-adb-wifi
ADB_BINARY=adb
ADB_WIFI_HOST=192.168.7.2
ADB_WIFI_PORT=5555

BOARD_TIMEOUT=15
BOARD_AUDIT_LOG=./audit.log
